<!DOCTYPE html>
<html>
  <head>
    <title>Zylkfar</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #2a0050, #0d0014);
        color: #ffffff;
        min-height: 100vh;
        animation: fadeIn 1.2s ease-out;
      }

      /* Top-left brand name */
      .header {
        position: absolute;
        top: 20px;
        left: 30px;
        font-size: 1.6rem;
        font-weight: bold;
        letter-spacing: 2px;
        text-shadow: 0 0 10px #b57bff;
      }

      /* Center content */
      .center {
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
      }

      h1 {
        font-size: 3rem;
        letter-spacing: 3px;
        margin-bottom: 12px;
        text-shadow: 0 0 12px #b57bff;
      }

      a {
        color: #c08aff;
        font-size: 1.2rem;
        text-decoration: none;
        transition: 0.3s ease;
      }

      a:hover {
        color: #ffffff;
        text-shadow: 0 0 10px #d3a6ff;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body>

    <!-- Brand name top-left -->
    <div class="header">Zylkfar</div>

    <!-- Centered content -->
    <div class="center">
      <h1>Under Construction</h1>
      <a href="/contact.html">Register your interest</a>
    </div>

  </body>
</html>
